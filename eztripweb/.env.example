# Example environment variables for EzTrip front-end
# Copy this file to .env and fill values before running the app

# App base URLs
REACT_APP_CLIENT_URL=http://localhost:3000
REACT_APP_SERVER_URL=http://localhost:8080

# -------------------------
# Firebase (client) config
# -------------------------
REACT_APP_FIREBASE_API_KEY=
REACT_APP_FIREBASE_AUTH_DOMAIN=
REACT_APP_FIREBASE_DATABASE_URL=
REACT_APP_FIREBASE_PROJECT_ID=
REACT_APP_FIREBASE_STORAGE_BUCKET=
REACT_APP_FIREBASE_MESSAGING_SENDER_ID=
REACT_APP_FIREBASE_APP_ID=
REACT_APP_FIREBASE_MEASUREMENT_ID=

# -------------------------
# Momo payment config
# -------------------------
# Use test values for development; do NOT commit real secrets
REACT_APP_MOMO_PARTNER_CODE=
REACT_APP_MOMO_ACCESS_KEY=
REACT_APP_MOMO_SECRET_KEY=
REACT_APP_MOMO_REQUEST_URL=https://test-payment.momo.vn/v2/gateway/api/create
REACT_APP_MOMO_RETURN_URL=${REACT_APP_CLIENT_URL}/payment-return
REACT_APP_MOMO_NOTIFY_URL=${REACT_APP_SERVER_URL}/api/momo/notify
REACT_APP_MOMO_ENV=test

# -------------------------
# Gemini / external AI service
# -------------------------
REACT_APP_GEMINI_API_KEY=
REACT_APP_GEMINI_BASE_URL=https://api.gemini.com
REACT_APP_GEMINI_MODEL=gpt-4o-mini

# -------------------------
# Optional: feature toggles and misc
# -------------------------
# e.g. enable debug logging in production-like envs
REACT_APP_ENABLE_DEBUG=false

# End of example
